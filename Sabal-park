const STORAGE_KEY = "sabal_park_budget_v1";

/* ============================================================
   STATE
   ============================================================ */
let state = null;

function load() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      state = JSON.parse(raw);
      // backfill any new assumption fields added in later versions,
      // so existing saved budgets don't break after an upgrade
      state.assumptions = Object.assign({}, DEFAULT_DATA.assumptions, state.assumptions || {});
      return;
    }
  } catch (e) { console.warn("load failed", e); }
  state = JSON.parse(JSON.stringify(DEFAULT_DATA));
}

let saveTimer = null;
function save() {
  const ind = document.getElementById("saveInd");
  ind.textContent = "Saving...";
  ind.classList.add("saving");
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      ind.textContent = "Saved " + new Date().toLocaleTimeString();
      ind.classList.remove("saving");
    } catch (e) {
      ind.textContent = "Save error";
    }
  }, 250);
}

/* ============================================================
   CALCULATIONS
   ============================================================ */
function fmt(n) {
  if (!isFinite(n)) n = 0;
  return "$" + n.toLocaleString("en-US", { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}
function fmt2(n) {
  if (!isFinite(n)) n = 0;
  return "$" + n.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function tenYearRent() {
  const a = state.assumptions;
  const annual1 = a.bldgSF * a.baseRent; // year 1 total
  const r = a.escalation / 100;
  let total = 0;
  for (let y = 0; y < 10; y++) {
    total += annual1 * Math.pow(1 + r, y);
  }
  return { annual1, total };
}

function commission() {
  const { total } = tenYearRent();
  return total * (state.assumptions.commRate / 100);
}

function calcNOI() {
  const a = state.assumptions;
  const gpr = a.bldgSF * a.baseRent;                    // gross potential rent, Y1
  const vacLoss = gpr * (a.vacancy / 100);
  const egi = gpr - vacLoss;
  const mgmt = egi * (a.mgmtFee / 100);
  const reserves = a.bldgSF * a.reserves;
  const noi = egi - mgmt - reserves;
  return { gpr, vacLoss, egi, mgmt, reserves, noi };
}

function calcDebtService() {
  const a = state.assumptions;
  const P = Number(a.loanAmt) || 0;
  const r = (Number(a.intRate) || 0) / 100 / 12;
  const n = (Number(a.amort) || 0) * 12;
  if (P <= 0 || r <= 0 || n <= 0) return 0;
  const pmt = P * r / (1 - Math.pow(1 + r, -n));
  return pmt * 12;
}

function calcReturns() {
  const a = state.assumptions;
  const tdc = grandTotal();
  const { noi } = calcNOI();
  const ds = calcDebtService();
  const roc = tdc > 0 ? noi / tdc : 0;
  const dscr = ds > 0 ? noi / ds : 0;
  const ltc = tdc > 0 ? (Number(a.loanAmt) || 0) / tdc : 0;
  const salePrice = a.exitCap > 0 ? noi / (a.exitCap / 100) : 0;
  const ltv = salePrice > 0 ? (Number(a.loanAmt) || 0) / salePrice : 0;
  const costOfSale = salePrice * (a.costSale / 100);
  const netSale = salePrice - costOfSale;
  const profit = netSale - tdc;
  const profitMargin = tdc > 0 ? profit / tdc : 0;
  return { tdc, noi, ds, roc, dscr, ltc, salePrice, ltv, costOfSale, netSale, profit, profitMargin };
}

function itemTotal(item) {
  if (item.autoCommission) return commission();
  return (Number(item.qty) || 0) * (Number(item.unitCost) || 0);
}

function categoryTotal(cat) {
  return cat.items.reduce((s, i) => s + itemTotal(i), 0);
}

function grandTotal() {
  return state.categories.reduce((s, c) => s + categoryTotal(c), 0);
}

/* ============================================================
   RENDER — Assumptions panel
   ============================================================ */
function renderAssumptions() {
  const a = state.assumptions;
  const ids = ["bldgSF","numTenants","baseRent","escalation","commRate","constrMonths",
               "loanAmt","vacancy","mgmtFee","reserves","intRate","amort","exitCap","costSale"];
  ids.forEach(id => {
    const el = document.getElementById(id);
    if (el && document.activeElement !== el) el.value = a[id];
  });

  document.getElementById("sfPerTenant").textContent =
    (a.bldgSF / Math.max(1, a.numTenants)).toLocaleString("en-US", { maximumFractionDigits: 0 }) + " SF";

  const { annual1, total } = tenYearRent();
  document.getElementById("y1Rent").textContent = fmt(annual1);
  document.getElementById("tenYrRent").textContent = fmt(total);
  document.getElementById("commCalc").textContent = fmt(commission());

  const { noi } = calcNOI();
  document.getElementById("noi").textContent = fmt(noi);

  const ds = calcDebtService();
  document.getElementById("debtSvc").textContent = fmt(ds);

  const gt = grandTotal();
  const equity = gt - (Number(a.loanAmt) || 0);
  document.getElementById("equityReq").textContent = fmt(equity);
}

function wireAssumptions() {
  const ids = ["bldgSF","numTenants","baseRent","escalation","commRate","constrMonths",
               "loanAmt","vacancy","mgmtFee","reserves","intRate","amort","exitCap","costSale"];
  ids.forEach(id => {
    document.getElementById(id).addEventListener("input", e => {
      const v = Number(e.target.value) || 0;
      state.assumptions[id] = v;
      renderAssumptions();
      // commission line in budget depends on rent — refresh budget totals
      // (only re-render the commission row's total; cheap enough to just re-render)
      renderBudget();
      renderSummary();
      save();
    });
  });
}

/* ============================================================
   RENDER — Budget table
   ============================================================ */
function renderBudget() {
  const tbody = document.getElementById("budgetBody");
  tbody.innerHTML = "";

  state.categories.forEach((cat, ci) => {
    // category header
    const crow = document.createElement("tr");
    crow.className = "category-row";
    crow.innerHTML = `
      <td contenteditable="true" data-cat="${ci}" class="cat-name">${escapeHtml(cat.name)}</td>
      <td></td><td></td><td></td>
      <td class="cat-total">${fmt(categoryTotal(cat))}</td>
      <td style="text-align:center;">
        <button class="row-del" data-del-cat="${ci}" title="Delete category">×</button>
      </td>
    `;
    tbody.appendChild(crow);

    // items
    cat.items.forEach((item, ii) => {
      const tr = document.createElement("tr");
      tr.dataset.cat = ci;
      tr.dataset.item = ii;
      const autoBadge = item.autoCommission ? '<span class="auto-badge">AUTO</span>' : '';
      const totalClass = item.autoCommission ? "total auto" : "total";
      tr.innerHTML = `
        <td><input class="desc" type="text" value="${escapeAttr(item.desc)}" />${autoBadge}</td>
        <td><input class="qty" type="number" step="any" value="${item.qty}" ${item.autoCommission ? "disabled" : ""}/></td>
        <td><input class="unit" type="text" value="${escapeAttr(item.unit)}" /></td>
        <td><input class="unit-cost" type="number" step="any" value="${item.unitCost}" ${item.autoCommission ? "disabled" : ""}/></td>
        <td class="${totalClass}">${fmt(itemTotal(item))}</td>
        <td style="text-align:center;">
          <button class="row-del" title="Delete line">×</button>
        </td>
      `;
      tbody.appendChild(tr);
    });

    // add-row / add-line inside category
    const add = document.createElement("tr");
    add.className = "add-row";
    add.innerHTML = `
      <td colspan="6">
        <button class="btn small" data-add-line="${ci}">+ Add line to ${escapeHtml(cat.name)}</button>
      </td>
    `;
    tbody.appendChild(add);
  });

  wireBudgetEvents();
}

function wireBudgetEvents() {
  // category name edit
  document.querySelectorAll(".cat-name").forEach(el => {
    el.addEventListener("blur", e => {
      const ci = +e.target.dataset.cat;
      state.categories[ci].name = e.target.textContent.trim() || "Untitled Category";
      save();
    });
  });

  // item input edits
  document.querySelectorAll("#budgetBody tr[data-item]").forEach(tr => {
    const ci = +tr.dataset.cat, ii = +tr.dataset.item;
    tr.querySelector(".desc").addEventListener("input", e => {
      state.categories[ci].items[ii].desc = e.target.value;
      save();
    });
    const qEl = tr.querySelector(".qty");
    qEl.addEventListener("input", e => {
      state.categories[ci].items[ii].qty = Number(e.target.value) || 0;
      updateRowTotals(tr, ci, ii);
      save();
    });
    tr.querySelector(".unit").addEventListener("input", e => {
      state.categories[ci].items[ii].unit = e.target.value;
      save();
    });
    tr.querySelector(".unit-cost").addEventListener("input", e => {
      state.categories[ci].items[ii].unitCost = Number(e.target.value) || 0;
      updateRowTotals(tr, ci, ii);
      save();
    });
    // delete line
    tr.querySelector(".row-del").addEventListener("click", () => {
      state.categories[ci].items.splice(ii, 1);
      renderBudget();
      renderSummary();
      renderAssumptions();
      save();
    });
  });

  // add line
  document.querySelectorAll("[data-add-line]").forEach(btn => {
    btn.addEventListener("click", e => {
      const ci = +e.target.dataset.addLine;
      state.categories[ci].items.push({
        desc: "New line item",
        qty: 1,
        unit: "LS",
        unitCost: 0
      });
      renderBudget();
      renderSummary();
      renderAssumptions();
      save();
    });
  });

  // delete category
  document.querySelectorAll("[data-del-cat]").forEach(btn => {
    btn.addEventListener("click", e => {
      const ci = +e.currentTarget.dataset.delCat;
      if (confirm(`Delete category "${state.categories[ci].name}" and all its line items?`)) {
        state.categories.splice(ci, 1);
        renderBudget();
        renderSummary();
        renderAssumptions();
        save();
      }
    });
  });
}

function updateRowTotals(tr, ci, ii) {
  const item = state.categories[ci].items[ii];
  tr.querySelector(".total").textContent = fmt(itemTotal(item));
  // update category row
  const catRow = tr.parentNode.querySelector(`tr.category-row[data-cat]`);
  // rerender just category total & summary to keep it simple
  const catRows = document.querySelectorAll("tr.category-row");
  catRows.forEach((cr, idx) => {
    cr.querySelector(".cat-total").textContent = fmt(categoryTotal(state.categories[idx]));
  });
  renderSummary();
  renderAssumptions();
}

/* ============================================================
   SUMMARY
   ============================================================ */
function renderSummary() {
  const hardCats = ["land", "hard"];
  let hard = 0, soft = 0;
  state.categories.forEach(c => {
    if (hardCats.includes(c.id)) hard += categoryTotal(c);
    else soft += categoryTotal(c);
  });
  const gt = grandTotal();
  const sf = state.assumptions.bldgSF || 1;
  document.getElementById("hardTotal").textContent = fmt(hard);
  document.getElementById("softTotal").textContent = fmt(soft);
  document.getElementById("grandTotal").textContent = fmt(gt);
  document.getElementById("costPSF").textContent = fmt(gt / sf);

  // Returns & Debt
  const r = calcReturns();
  const pct = v => (v * 100).toLocaleString("en-US", { maximumFractionDigits: 2 }) + "%";
  const x = v => v.toLocaleString("en-US", { maximumFractionDigits: 2 }) + "x";

  const rocEl = document.getElementById("roc");
  rocEl.textContent = pct(r.roc);
  rocEl.className = "value " + classByThreshold(r.roc, 0.08, 0.075, "up"); // >=8% good, 7.5-8% warn, <7.5% bad
  document.getElementById("rocSub").textContent =
    "NOI " + fmt(r.noi) + " ÷ " + fmt(r.tdc);

  const dscrEl = document.getElementById("dscr");
  dscrEl.textContent = r.ds > 0 ? x(r.dscr) : "—";
  dscrEl.className = "value " + classByThreshold(r.dscr, 1.25, 1.15, "up"); // >=1.25 good, 1.15-1.25 warn
  document.getElementById("dscrSub").textContent =
    r.ds > 0
      ? "NOI ÷ " + fmt(r.ds) + " DS"
      : "Set loan, rate & amort";

  const ltcEl = document.getElementById("ltc");
  ltcEl.textContent = pct(r.ltc);
  ltcEl.className = "value " + classByThreshold(r.ltc, 0.75, 0.85, "down"); // <=75% good, 75-85% warn
  document.getElementById("ltcSub").textContent =
    fmt(state.assumptions.loanAmt || 0) + " ÷ " + fmt(r.tdc) + " · Valley cap 75%";

  const ltvEl = document.getElementById("ltv");
  ltvEl.textContent = r.salePrice > 0 ? pct(r.ltv) : "—";
  ltvEl.className = "value " + classByThreshold(r.ltv, 0.70, 0.75, "down"); // <=70% good
  document.getElementById("ltvSub").textContent =
    r.salePrice > 0
      ? fmt(state.assumptions.loanAmt || 0) + " ÷ " + fmt(r.salePrice) + " · Valley cap 70%"
      : "Set exit cap rate";

  // Exit / Sale
  document.getElementById("salePrice").textContent = fmt(r.salePrice);
  document.getElementById("salePriceSub").textContent =
    fmt(r.noi) + " ÷ " + (state.assumptions.exitCap || 0).toFixed(2) + "% cap";

  document.getElementById("costOfSaleVal").textContent = fmt(r.costOfSale);
  document.getElementById("costOfSaleSub").textContent =
    (state.assumptions.costSale || 0).toFixed(2) + "% of sale price";

  document.getElementById("netSale").textContent = fmt(r.netSale);

  const profitEl = document.getElementById("profit");
  profitEl.textContent = fmt(r.profit);
  document.getElementById("profitSub").textContent =
    "Margin " + pct(r.profitMargin) + " on cost";
}

function classByThreshold(v, goodAt, warnAt, direction) {
  // direction "up" = higher is better; "down" = lower is better
  if (direction === "up") {
    if (v >= goodAt) return "metric-good";
    if (v >= warnAt) return "metric-warn";
    return "metric-bad";
  } else {
    if (v <= goodAt) return "metric-good";
    if (v <= warnAt) return "metric-warn";
    return "metric-bad";
  }
}

/* ============================================================
   ADD CATEGORY / RESET / EXPORT
   ============================================================ */
document.getElementById("addCategoryBtn").addEventListener("click", () => {
  const name = prompt("Category name?", "New Category");
  if (!name) return;
  state.categories.push({
    id: "c" + Date.now(),
    name: name,
    items: [{ desc: "New line item", qty: 1, unit: "LS", unitCost: 0 }]
  });
  renderBudget();
  renderSummary();
  renderAssumptions();
  save();
});

document.getElementById("resetBtn").addEventListener("click", () => {
  if (confirm("Reset to the default Sabal Park budget? All your edits will be lost.")) {
    state = JSON.parse(JSON.stringify(DEFAULT_DATA));
    renderAll();
    save();
  }
});

document.getElementById("exportBtn").addEventListener("click", () => {
  let csv = "Category,Description,Qty,Unit,Unit Cost,Total\n";
  state.categories.forEach(c => {
    c.items.forEach(i => {
      const total = itemTotal(i);
      csv += [
        csvEsc(c.name),
        csvEsc(i.desc),
        i.qty,
        csvEsc(i.unit),
        i.unitCost,
        total.toFixed(2)
      ].join(",") + "\n";
    });
    csv += `"${c.name} TOTAL",,,,,${categoryTotal(c).toFixed(2)}\n`;
  });
  csv += `\nGRAND TOTAL,,,,,${grandTotal().toFixed(2)}\n`;
  csv += `Cost PSF,,,,,${(grandTotal() / state.assumptions.bldgSF).toFixed(2)}\n`;

  const blob = new Blob([csv], { type: "text/csv" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "Sabal_Park_Budget_" + new Date().toISOString().slice(0, 10) + ".csv";
  a.click();
});

function csvEsc(s) {
  s = String(s);
  if (s.includes(",") || s.includes('"') || s.includes("\n")) {
    return '"' + s.replace(/"/g, '""') + '"';
  }
  return s;
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"]/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));
}
function escapeAttr(s) {
  return String(s).replace(/"/g, "&quot;");
}

/* ============================================================
   BOOT
   ============================================================ */
function renderAll() {
  renderAssumptions();
  renderBudget();
  renderSummary();
  renderAssumptions(); // refresh equity after budget renders
}

load();
wireAssumptions();
renderAll();
</script>
