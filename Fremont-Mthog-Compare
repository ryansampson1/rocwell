<script>
// ─── Defaults ────────────────────────────────────────────────────────────────
const DEFAULTS = {
  analysisDate:     '2026-07-01',
  // Mathog
  mathogPrefStart:  '2022-09-13',
  t1Rent: '215000', t1Cap: '5.75%',
  t2Rent: '77500',  t2Cap: '5.25%',
  t3Rent: '125000', t3Cap: '7.00%',
  mathogCostPct: '2.00%', mathogTI: '150000', mathogLC: '150000', mathogDebt: '4100000',
  // Fremont
  fremontPrefStart: '2022-09-13',
  gr2PrefStart:     '2022-10-14',
  fremontPropVal:   '10000000',
  fremontCostPct:   '2.00%', fremontTI: '0', fremontLC: '0', fremontDebt: '6800000',
  grPrefEq: '500000', grPrefRate: '10.00%',
  gr2PrefEq: '103768', gr2PrefRate: '10.00%',
};

// ─── File Auto-Save ───────────────────────────────────────────────────────────
let _fileHandle = null, _saveTimer = null;
async function enableFileSave() {
  if (!window.showOpenFilePicker) { setSaveStatus('⚠ Use Chrome for file save','#c00'); return; }
  try {
    const [h] = await window.showOpenFilePicker({ types:[{description:'HTML',accept:{'text/html':['.html']}}], multiple:false });
    _fileHandle = h;
    document.getElementById('file-save-btn').textContent = '📁 File Auto-Save ON';
    setSaveStatus('Enabled ✓','#7ec8f0');
    await writeToFile();
  } catch(e) { if(e.name!=='AbortError') setSaveStatus('Error: '+e.message,'#f87'); }
}
async function writeToFile() {
  if (!_fileHandle) return;
  try {
    const cur = {}; Object.keys(DEFAULTS).forEach(id => { const el=document.getElementById(id); cur[id]=el?el.value:DEFAULTS[id]; });
    const nd = `const DEFAULTS = {\n  analysisDate:     '${cur.analysisDate}',\n  // Mathog\n  mathogPrefStart:  '${cur.mathogPrefStart}',\n  t1Rent: '${cur.t1Rent}', t1Cap: '${cur.t1Cap}',\n  t2Rent: '${cur.t2Rent}',  t2Cap: '${cur.t2Cap}',\n  t3Rent: '${cur.t3Rent}', t3Cap: '${cur.t3Cap}',\n  mathogCostPct: '${cur.mathogCostPct}', mathogTI: '${cur.mathogTI}', mathogLC: '${cur.mathogLC}', mathogDebt: '${cur.mathogDebt}',\n  // Fremont\n  fremontPrefStart: '${cur.fremontPrefStart}',\n  gr2PrefStart:     '${cur.gr2PrefStart}',\n  fremontPropVal:   '${cur.fremontPropVal}',\n  fremontCostPct:   '${cur.fremontCostPct}', fremontTI: '${cur.fremontTI}', fremontLC: '${cur.fremontLC}', fremontDebt: '${cur.fremontDebt}',\n  grPrefEq: '${cur.grPrefEq}', grPrefRate: '${cur.grPrefRate}',\n  gr2PrefEq: '${cur.gr2PrefEq}', gr2PrefRate: '${cur.gr2PrefRate}',\n};`;
    const file = await _fileHandle.getFile(); let html = await file.text();
    html = html.replace(/const DEFAULTS = \{[\s\S]*?\};/, nd);
    const w = await _fileHandle.createWritable(); await w.write(html); await w.close();
    setSaveStatus('Saved ✓ '+new Date().toLocaleTimeString(),'#7ec8f0');
  } catch(e) { setSaveStatus('Save failed','#f87'); }
}
function scheduleFileSave() { clearTimeout(_saveTimer); _saveTimer=setTimeout(writeToFile,700); }
function setSaveStatus(m,c) { const el=document.getElementById('save-status'); if(el){el.textContent=m;el.style.color=c||'#7ec8f0';} }

// ─── Persistence ──────────────────────────────────────────────────────────────
function save(id) { const el=document.getElementById(id); if(el){ localStorage.setItem('swap_'+id,el.value); if(_fileHandle)scheduleFileSave(); } }
function load(id) { return localStorage.getItem('swap_'+id); }
function initInputs() { Object.keys(DEFAULTS).forEach(id=>{ const el=document.getElementById(id); if(!el)return; const s=load(id); el.value=(s!==null)?s:DEFAULTS[id]; }); }
function resetDefaults() {
  if(!confirm('Reset all inputs to defaults?')) return;
  Object.keys(DEFAULTS).forEach(id=>{ localStorage.removeItem('swap_'+id); const el=document.getElementById(id); if(el)el.value=DEFAULTS[id]; });
  calc();
}

// ─── Helpers ─────────────────────────────────────────────────────────────────
const fmt = new Intl.NumberFormat('en-US',{style:'currency',currency:'USD',minimumFractionDigits:0,maximumFractionDigits:0});
const fmtY = new Intl.NumberFormat('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
function parseMoney(s) { return parseFloat(String(s).replace(/[$,%\s]/g,''))||0; }
function parsePct(s) { const v=parseFloat(String(s).replace(/[%\s]/g,'')); return isNaN(v)?0:(v>1?v/100:v); }
function daysBetween(a,b) { const s=new Date(a+'T00:00:00'),e=new Date(b+'T00:00:00'); if(isNaN(s)||isNaN(e))return null; return Math.round((e-s)/86400000); }
function setM(id,v,force0) {
  const el=document.getElementById(id); if(!el)return;
  if(v===null||isNaN(v)){el.textContent='—';el.className='val dash';return;}
  el.textContent=fmt.format(v);
  el.className='val'+(v<0?' neg':v>0?' pos':'');
}
function setMCell(id,v) { const el=document.getElementById(id); if(!el)return; if(v===null||isNaN(v)){el.textContent='—';return;} el.textContent=fmt.format(v); }
function setTxt(id,v) { const el=document.getElementById(id); if(el)el.textContent=v; }
function setWfAmt(id,v) { const el=document.getElementById(id); if(!el)return; el.textContent=(v===null||isNaN(v))?'—':fmt.format(v); }

// ─── Main Calc ────────────────────────────────────────────────────────────────
function calc() {
  const analysisDate = document.getElementById('analysisDate').value;
  document.getElementById('hdr_date').textContent = analysisDate || '—';

  // ── MATHOG ──────────────────────────────────────────────────────────────
  const mathogStart = document.getElementById('mathogPrefStart').value;
  const mDays = daysBetween(mathogStart, analysisDate);
  const mYears = mDays !== null ? mDays / 365 : 0;
  setTxt('mathogYears', mDays !== null ? fmtY.format(mYears)+' yrs' : '—');

  const t1r = parseMoney(document.getElementById('t1Rent').value);
  const t1c = parsePct(document.getElementById('t1Cap').value);
  const t2r = parseMoney(document.getElementById('t2Rent').value);
  const t2c = parsePct(document.getElementById('t2Cap').value);
  const t3r = parseMoney(document.getElementById('t3Rent').value);
  const t3c = parsePct(document.getElementById('t3Cap').value);
  const t1v = t1c > 0 ? t1r / t1c : 0;
  const t2v = t2c > 0 ? t2r / t2c : 0;
  const t3v = t3c > 0 ? t3r / t3c : 0;
  setM('t1Val', t1v || null); setM('t2Val', t2v || null); setM('t3Val', t3v || null);
  const mathogProp = t1v + t2v + t3v;
  setM('mathogPropVal', mathogProp || null);

  const mCostPct = parsePct(document.getElementById('mathogCostPct').value);
  const mTI      = parseMoney(document.getElementById('mathogTI').value);
  const mLC      = parseMoney(document.getElementById('mathogLC').value);
  const mDebt    = parseMoney(document.getElementById('mathogDebt').value);
  const mathogNetEquity = mathogProp - mathogProp * mCostPct - mTI - mLC - mDebt;
  setM('mathogNetEq', mathogProp ? mathogNetEquity : null);
  setTxt('mathogNetEq2', mathogProp ? fmt.format(mathogNetEquity) : '—');

  // Mathog equity stack (fixed)
  const mGrPref = 500000, mGrRate = 0.10;
  const mRsPref = 275000, mRsRate = 0.10;
  const mRgPref = 300000, mRgRate = 0.10;
  const mJbCom = 485000, mRsCom = 485000, mRgCom = 485000;
  const mTotalCom = mJbCom + mRsCom + mRgCom;

  // Accrued prefs
  const mGrAcc = mGrPref * mGrRate * mYears;
  const mRsAcc = mRsPref * mRsRate * mYears;
  const mRgAcc = mRgPref * mRgRate * mYears;
  const mPartnerAcc = mRsAcc + mRgAcc;
  const mPartnerPref = mRsPref + mRgPref;

  // Waterfall
  let rem = mathogNetEquity;
  const mt1 = Math.max(0, Math.min(rem, mGrAcc));   rem -= mt1;
  const mt2 = Math.max(0, Math.min(rem, mGrPref));   rem -= mt2;
  const mt3 = Math.max(0, Math.min(rem, mPartnerAcc)); rem -= mt3;
  const mt4 = Math.max(0, Math.min(rem, mPartnerPref)); rem -= mt4;
  const mt5 = Math.max(0, Math.min(rem, mTotalCom));  rem -= mt5;
  const mt6 = Math.max(0, rem);

  setWfAmt('m_t1', mt1); setWfAmt('m_t2', mt2); setWfAmt('m_t3', mt3);
  setWfAmt('m_t4', mt4); setWfAmt('m_t5', mt5); setWfAmt('m_t6', mt6);

  // Party distributions
  const mGrTot = mt1 + mt2;
  const rsAccShare = mPartnerAcc > 0 ? mt3 * (mRsAcc / mPartnerAcc) : 0;
  const rgAccShare = mPartnerAcc > 0 ? mt3 * (mRgAcc / mPartnerAcc) : 0;
  const rsCapShare = mPartnerPref > 0 ? mt4 * (mRsPref / mPartnerPref) : 0;
  const rgCapShare = mPartnerPref > 0 ? mt4 * (mRgPref / mPartnerPref) : 0;
  const comEach = mt5 / 3;
  const resEach = mt6 / 3;

  const mJbTot = comEach + resEach;
  const mRsTot = rsAccShare + rsCapShare + comEach + resEach;
  const mRgTot = rgAccShare + rgCapShare + comEach + resEach;

  setM('m_gr_tot', mGrTot || null); setM('m_jb_tot', mJbTot || null);
  setM('m_rs_tot', mRsTot || null); setM('m_rg_tot', mRgTot || null);

  // ── FREMONT ─────────────────────────────────────────────────────────────
  const fremontStart = document.getElementById('fremontPrefStart').value;
  const gr2Start     = document.getElementById('gr2PrefStart').value;
  const fDays  = daysBetween(fremontStart, analysisDate);
  const fYears = fDays !== null ? fDays / 365 : 0;
  const gr2Days  = daysBetween(gr2Start, analysisDate);
  const gr2Years = gr2Days !== null ? gr2Days / 365 : 0;
  setTxt('fremontYears', fDays !== null ? fmtY.format(fYears)+' yrs' : '—');

  const fPropVal  = parseMoney(document.getElementById('fremontPropVal').value);
  const fCostPct  = parsePct(document.getElementById('fremontCostPct').value);
  const fTI       = parseMoney(document.getElementById('fremontTI').value);
  const fLC       = parseMoney(document.getElementById('fremontLC').value);
  const fDebt     = parseMoney(document.getElementById('fremontDebt').value);
  const fremontNetEquity = fPropVal - fPropVal * fCostPct - fTI - fLC - fDebt;
  setM('fremontNetEq', fPropVal ? fremontNetEquity : null);
  setTxt('fremontNetEq2', fPropVal ? fmt.format(fremontNetEquity) : '—');

  const grPrefEq  = parseMoney(document.getElementById('grPrefEq').value);
  const grRate    = parsePct(document.getElementById('grPrefRate').value);
  const gr2PrefEq = parseMoney(document.getElementById('gr2PrefEq').value);
  const gr2Rate   = parsePct(document.getElementById('gr2PrefRate').value);

  const grAcc  = grPrefEq  * grRate  * fYears;
  const gr2Acc = gr2PrefEq * gr2Rate * gr2Years;

  let frem = fremontNetEquity;
  const ft1 = Math.max(0, Math.min(frem, grAcc));    frem -= ft1;
  const ft2 = Math.max(0, Math.min(frem, grPrefEq)); frem -= ft2;
  const ft3 = Math.max(0, Math.min(frem, gr2Acc));   frem -= ft3;
  const ft4 = Math.max(0, Math.min(frem, gr2PrefEq));frem -= ft4;
  // tiers 5–7: no partner prefs or common → $0
  const ft8 = Math.max(0, frem);

  setWfAmt('f_t1', ft1); setWfAmt('f_t2', ft2); setWfAmt('f_t3', ft3);
  setWfAmt('f_t4', ft4); setWfAmt('f_t57', 0);  setWfAmt('f_t8', ft8);

  const fGrTot  = ft1 + ft2;
  const fGr2Tot = ft3 + ft4;
  const fResEach = ft8 / 3;

  setM('f_gr_tot',  fGrTot  || null); setM('f_gr2_tot', fGr2Tot || null);
  setM('f_jb_tot',  fResEach || null); setM('f_rs_tot', fResEach || null);
  setM('f_rg_tot',  fResEach || null);

  // ── SWAP ANALYSIS ────────────────────────────────────────────────────────
  // Positions being swapped:
  const mathogP1   = mJbTot;    // JB's current Mathog position (P1)
  const mathogP2   = mRsTot;    // RS's current Mathog position (P2)
  const fremontGR  = fGrTot;    // GR's current Fremont position (pref tiers 1–2)
  const fremontRG  = fResEach;  // RG's current Fremont position (1/3 residual)

  // Deltas
  const jbDelta = fremontGR - mathogP1;   // JB: gives P1, gets GR's Fremont pref
  const rsDelta = fremontRG - mathogP2;   // RS: gives P2, gets RG's Fremont residual
  const grDelta = mathogP1  - fremontGR;  // GR: gives Fremont pref, gets P1
  const rgDelta = mathogP2  - fremontRG;  // RG: gives Fremont residual, gets P2

  // Swap table
  setMCell('sw_jb_cur', mathogP1);   setMCell('sw_jb_new', fremontGR);
  setMCell('sw_rs_cur', mathogP2);   setMCell('sw_rs_new', fremontRG);
  setMCell('sw_gr_cur', fremontGR);  setMCell('sw_gr_new', mathogP1);
  setMCell('sw_rg_cur', fremontRG);  setMCell('sw_rg_new', mathogP2);

  function setDeltaCell(id, v) {
    const el = document.getElementById(id); if(!el)return;
    el.textContent = fmt.format(v);
    el.style.color = v > 0 ? '#2d7a2d' : v < 0 ? '#c00' : '#888';
  }
  setDeltaCell('sw_jb_delta', jbDelta); setDeltaCell('sw_rs_delta', rsDelta);
  setDeltaCell('sw_gr_delta', grDelta); setDeltaCell('sw_rg_delta', rgDelta);

  // Delta cards
  function fillCard(prefix, delta, curVal, newVal) {
    const el = document.getElementById('dc_'+prefix+'_delta');
    const lb = document.getElementById('dc_'+prefix+'_label');
    const ar = document.getElementById('dc_'+prefix+'_arrow');
    if (!el) return;
    el.textContent = fmt.format(delta);
    el.className = 'delta-val' + (delta > 0 ? ' pos' : delta < 0 ? ' neg' : ' zero');
    lb.textContent = (delta > 0 ? '▲ Better off' : delta < 0 ? '▼ Worse off' : '= No change') + ' vs current position';
    ar.textContent = delta > 0
      ? `Was ${fmt.format(curVal)} → Now ${fmt.format(newVal)}`
      : `Was ${fmt.format(curVal)} → Now ${fmt.format(newVal)}`;
  }
  fillCard('jb', jbDelta, mathogP1, fremontGR);
  fillCard('rs', rsDelta, mathogP2, fremontRG);
  fillCard('gr', grDelta, fremontGR, mathogP1);
  fillCard('rg', rgDelta, fremontRG, mathogP2);

  // ── CASH EQUALIZATION ────────────────────────────────────────────────────
  function fillEqualization(prefix, delta, partyA, partyB) {
    // partyA gives up their current position, receives the other
    // if delta > 0, partyA benefits → partyA pays partyB
    // if delta < 0, partyB benefits → partyB pays partyA
    const winner = delta > 0 ? partyA : partyB;
    const loser  = delta > 0 ? partyB : partyA;
    const amount = Math.abs(delta);
    const dir    = delta > 0
      ? `${partyA} → pays → ${partyB}`
      : `${partyB} → pays → ${partyA}`;
    setTxt(prefix+'_winner', winner);
    setTxt(prefix+'_loser',  loser);
    const advEl = document.getElementById(prefix+'_adv');
    if (advEl) { advEl.textContent = fmt.format(amount); advEl.style.color = '#5a3e8a'; advEl.style.fontWeight='700'; }
    const payEl = document.getElementById(prefix+'_pay');
    if (payEl) { payEl.textContent = fmt.format(amount); payEl.style.color = '#5a3e8a'; }
    setTxt(prefix+'_dir', dir);
  }
  fillEqualization('eq_jbgr', jbDelta, 'JB', 'GR');
  fillEqualization('eq_rsrg', rsDelta, 'RS', 'RG');

  // ── POST-SWAP FREMONT RESIDUAL OWNERSHIP ─────────────────────────────────
  // Before swap: JB=1/3, RS=1/3, RG=1/3 of ft8
  // After swap: RG exits → RS gets RG's 1/3.  Result: JB=1/3, RS=2/3, RG=0
  const jbBefore = ft8 / 3;
  const rsBefore = ft8 / 3;
  const rgBefore = ft8 / 3;
  const jbAfter  = ft8 / 3;         // JB's own residual unchanged
  const rsAfter  = (ft8 / 3) * 2;   // RS's own 1/3 + RG's 1/3

  function setOwn(id, v) {
    const el = document.getElementById(id); if(!el)return;
    el.textContent = v !== null && !isNaN(v) ? fmt.format(v) : '—';
  }
  setOwn('own_jb_before', jbBefore); setOwn('own_jb_after', jbAfter);
  setOwn('own_rs_before', rsBefore); setOwn('own_rs_after', rsAfter);
  setOwn('own_rg_before', rgBefore);
  setOwn('own_total_before', ft8);   setOwn('own_total_after', ft8);

  // Pro-rata: JB = 1/3 = 33.33%, RS = 2/3 = 66.67%
  setTxt('own_jb_pct', '33.33%');
  setTxt('own_rs_pct', '66.67%');
  setOwn('own_jb_val', jbAfter);
  setOwn('own_rs_val', rsAfter);

  // JB buy-up to 50/50: needs to acquire 1/6 of total residual from RS
  // Cost = ft8 × (1/6)
  const buyup = ft8 / 6;
  setOwn('own_jb_buyup', buyup);

  // After buy-up: JB has 1/2 residual, paid 1/6 → net = 1/2 × ft8 − 1/6 × ft8 = 1/3 × ft8
  // Wait — JB already HAS 1/3 × ft8. After paying 1/6 for the additional 1/6 share:
  // JB's residual VALUE = 1/2 × ft8. Net of payment = 1/2 × ft8 − 1/6 × ft8 = 1/3 × ft8 (same as before)
  // RS receives 1/6 × ft8, so RS residual net = 1/2 × ft8 + 1/6 × ft8 = 4/6 × ft8 (wait, RS gives up 1/6 share)
  // After buy-up: RS owns 1/2 residual. RS receives cash 1/6 × ft8. Net to RS = 1/2 × ft8 + 1/6 × ft8
  // Hmm — let's be clear: JB pays RS cash = ft8/6 to acquire 1/6 share of residual
  // JB net = (new residual claim: 1/2 × ft8) − (cash paid: 1/6 × ft8) = 3/6 × ft8 − 1/6 × ft8 = 2/6 = 1/3 × ft8
  // RS net = (new residual claim: 1/2 × ft8) + (cash received: 1/6 × ft8) = 3/6 + 1/6 = 4/6 × ft8
  // Actually the cleaner way: JB started with 1/3 of residual (as a future claim). Pays cash 1/6 × ft8 today.
  // After: JB has 1/2 future claim − 1/6 cash paid = net economic value gain of 1/6 × ft8 − 1/6 × ft8 = 0 net change (fair price)
  // RS: gives up 1/6 future claim, receives 1/6 cash → net 0 (fair)
  // So display: JB residual claim after = 1/2 × ft8, RS residual claim after = 1/2 × ft8
  setOwn('own_jb_net_buyup', ft8 / 2);  // JB's residual claim = 50% of ft8
  setOwn('own_rs_net_buyup', ft8 / 2);  // RS's residual claim = 50% of ft8
}

// ─── Boot ────────────────────────────────────────────────────────────────────
initInputs();
calc();
</script>
